workspace "EduFlow Digital Corp." "Arquitectura de Software Emergentes - Examen Parcial" {

    model {
        # ========== 1. PERSONAS (ACTORES) ==========
        clienteInstitucional = person "Cliente Institucional" "Institución educativa o empresa que contrata EduFlow"
        profesionalIndependiente = person "Profesional Independiente" "Usuario individual que paga suscripción"
        citizenDeveloper = person "Citizen Developer" "Usuario no técnico que crea apps con No-Code"
        administradorTI = person "Administrador TI" "Gestiona usuarios, suscripciones y plataforma"

        # ========== 2. SISTEMAS EXTERNOS ==========
        sistemaPagos = softwareSystem "Sistema de Pagos" "Stripe / Microsoft Pay" "External,Pagos"
        sistemaERPCRM = softwareSystem "ERP/CRM Cliente" "Sistemas empresariales externos del cliente" "External,ERP"
        
        # ========== 3. SISTEMA PRINCIPAL ==========
        eduflow = softwareSystem "EduFlow Integrated Digital Platform" "Plataforma digital integrada para automatización y creación rápida de aplicaciones" {
            
            # === 3.1 CONTENEDORES - FRONTENDS ===
            webApp = container "Web App" "Aplicación web principal para administradores y clientes" "Angular 17 / TypeScript" "Angular,WebApp"
            mobileApp = container "Mobile App" "App móvil empresarial para Android/iOS" "Flutter / React Native" "MobileApp"
            powerAppsPortal = container "Power Apps Portal" "Plataforma No-Code para Citizen Developers" "Power Apps / Power Pages" "PowerPlatform,NoCode"
            
            # === 3.2 CONTENEDOR - API GATEWAY ===
            apiGateway = container "API Gateway" "Punto de entrada único para todas las peticiones" "Azure API Management" "Gateway"
            
            # === 3.3 CONTENEDORES - MICROSERVICIOS (BOUNDED CONTEXTS) ===
            # Cada BC es un contenedor independiente con su propia base de datos
            
            # IAM
            iamService = container "Identity & Access Management" "Autenticación, SSO, gestión de identidades y autorización" "Azure Functions / Azure AD B2C" "Microservice"
            iamDatabase = container "IAM Database" "Usuarios, roles, sesiones, permisos" "Azure SQL / PostgreSQL" "Database"
            
            # Billing
            billingService = container "Subscription & Billing Management" "Gestión de suscripciones, facturación y pagos" "Azure Functions / Stripe" "Microservice"
            billingDatabase = container "Billing Database" "Suscripciones, invoices, payment methods" "Azure SQL / PostgreSQL" "Database"
            
            # Workflow
            workflowService = container "Workflow Management" "Automatización de procesos y workflows empresariales" "Power Automate / Logic Apps" "Microservice"
            workflowDatabase = container "Workflow Database" "Definiciones de workflows, ejecuciones, historial" "Azure SQL / PostgreSQL" "Database"
            
            # No-Code
            noCodeService = container "No-Code App Builder" "Constructor visual de aplicaciones No-Code" "Power Apps / Azure Functions" "Microservice"
            noCodeDatabase = container "NoCode Database" "Definiciones de apps, páginas, data sources" "Azure SQL / Cosmos DB" "Database"
            noCodeStorage = container "NoCode Blob Storage" "Assets de apps (imágenes, configuraciones)" "Azure Blob Storage" "Storage"
            
            # Low-Code Integration
            lowCodeService = container "Low-Code Integration Services" "Integración con ERP, CRM y sistemas externos" "Azure Logic Apps / API Management" "Microservice"
            lowCodeDatabase = container "LowCode Database" "Conectores, mappings, credenciales, logs" "Azure SQL / PostgreSQL" "Database"
            
            # Analytics
            analyticsService = container "Digital Analytics Services" "Dashboards, KPIs y reporting avanzado" "Power BI / Azure Synapse" "Microservice"
            analyticsDatabase = container "Analytics Database" "Agregados, snapshots, datasets" "Azure Synapse / SQL" "Database"
            
            # AI Assistant
            aiService = container "AI Assistant Services" "Asistentes virtuales con IA Generativa" "Azure OpenAI Service / Functions" "Microservice"
            aiDatabase = container "AI Database" "Conversaciones, mensajes, contextos" "Cosmos DB" "Database"
            
            # Notifications
            notificationService = container "Notification & Messaging Services" "Envío de notificaciones y mensajes" "Azure Event Grid / Functions" "Microservice"
            notificationDatabase = container "Notification Database" "Templates, histórico, colas" "Azure SQL" "Database"
            
            # Content & Document Management
            contentService = container "Content & Document Management" "Gestión documental y firma electrónica" "Azure Functions" "Microservice"
            contentDatabase = container "Content Database" "Metadatos de documentos, firmas" "Azure SQL" "Database"
            contentStorage = container "Content Blob Storage" "Documentos PDF, imágenes, firmas" "Azure Blob Storage" "Storage"
            
            # User Profiles
            profileService = container "User Profiles" "Gestión de perfiles de usuario y preferencias" "AKS / Azure Functions" "Microservice"
            profileDatabase = container "Profile Database" "Perfiles, preferencias, settings" "Azure SQL / PostgreSQL" "Database"
            
            # API Integration
            apiIntegrationService = container "API Integration Services" "Gestión centralizada de APIs y conectores" "Azure API Management / Logic Apps" "Microservice"
            apiIntegrationDatabase = container "APIIntegration Database" "API keys, rate limits, logs" "Azure SQL" "Database"
            
            # Shared Services
            sharedService = container "Shared Services" "Servicios transversales (logging, monitoreo, caché)" "Azure Redis / App Insights" "Shared Kernel,Microservice"
            
            # === 3.4 CONTENEDOR - EVENT GRID (Infraestructura compartida) ===
            eventGrid = container "Event Grid" "Mensajería asíncrona entre microservicios" "Azure Event Grid" "MessageBroker"
        }

        # ========== 4. RELACIONES DE PERSONAS CON SISTEMA ==========
        clienteInstitucional -> eduflow "Contrata servicios y accede a dashboards" "HTTPS"
        profesionalIndependiente -> eduflow "Paga suscripción y accede a contenido" "HTTPS"
        citizenDeveloper -> eduflow "Crea aplicaciones No-Code" "HTTPS"
        administradorTI -> eduflow "Administra plataforma y usuarios" "HTTPS"
        
        # Relaciones directas de personas a contenedores específicos
        administradorTI -> webApp "Gestiona la plataforma" "HTTPS"
        clienteInstitucional -> webApp "Accede a dashboards y cursos" "HTTPS"
        profesionalIndependiente -> mobileApp "Accede desde dispositivos móviles" "HTTPS"
        citizenDeveloper -> powerAppsPortal "Crea y publica aplicaciones" "HTTPS"
        
        # ========== 5. RELACIONES DEL SISTEMA CON EXTERNOS ==========
        eduflow -> sistemaPagos "Procesa suscripciones y pagos" "Stripe API / Microsoft Pay API"
        eduflow -> sistemaERPCRM "Se integra con sistemas del cliente" "REST / SOAP / OData"

        # ========== 6. RELACIONES DE CONTENEDORES ==========
        
        # Frontends -> API Gateway
        webApp -> apiGateway "Consume APIs protegidas" "HTTPS/REST"
        mobileApp -> apiGateway "Consume APIs para móvil" "HTTPS/REST"
        powerAppsPortal -> apiGateway "Consume APIs para No-Code" "HTTPS/REST"
        
        # API Gateway -> Microservicios
        apiGateway -> iamService "Rutea peticiones de auth" "HTTPS/REST"
        apiGateway -> billingService "Rutea peticiones de suscripciones" "HTTPS/REST"
        apiGateway -> workflowService "Rutea peticiones de workflows" "HTTPS/REST"
        apiGateway -> noCodeService "Rutea peticiones de No-Code" "HTTPS/REST"
        apiGateway -> lowCodeService "Rutea peticiones de integración" "HTTPS/REST"
        apiGateway -> analyticsService "Rutea peticiones de analytics" "HTTPS/REST"
        apiGateway -> aiService "Rutea peticiones de AI" "HTTPS/REST"
        apiGateway -> notificationService "Rutea peticiones de notificaciones" "HTTPS/REST"
        apiGateway -> contentService "Rutea peticiones de documentos" "HTTPS/REST"
        apiGateway -> profileService "Rutea peticiones de perfiles" "HTTPS/REST"
        apiGateway -> apiIntegrationService "Rutea peticiones de APIs" "HTTPS/REST"
        apiGateway -> sharedService "Rutea peticiones de servicios comunes" "HTTPS/REST"
        
        # Microservicios -> Sus propias bases de datos
        iamService -> iamDatabase "Lee/escribe" "SQL/TCP"
        billingService -> billingDatabase "Lee/escribe" "SQL/TCP"
        workflowService -> workflowDatabase "Lee/escribe" "SQL/TCP"
        noCodeService -> noCodeDatabase "Lee/escribe definiciones" "SQL/REST"
        noCodeService -> noCodeStorage "Almacena assets" "REST API"
        lowCodeService -> lowCodeDatabase "Lee/escribe" "SQL/TCP"
        analyticsService -> analyticsDatabase "Lee/escribe agregados" "SQL/TCP"
        aiService -> aiDatabase "Lee/escribe conversaciones" "REST/TCP"
        notificationService -> notificationDatabase "Lee/escribe" "SQL/TCP"
        contentService -> contentDatabase "Lee/escribe metadatos" "SQL/TCP"
        contentService -> contentStorage "Almacena documentos" "REST API"
        profileService -> profileDatabase "Lee/escribe" "SQL/TCP"
        apiIntegrationService -> apiIntegrationDatabase "Lee/escribe" "SQL/TCP"
        
        # Microservicios -> Sistemas Externos
        billingService -> sistemaPagos "Procesa checkout y webhooks" "Stripe API"
        lowCodeService -> sistemaERPCRM "Conecta con sistemas externos" "REST/SOAP"
        
        # Microservicios -> Event Grid (EDA)
        workflowService -> eventGrid "Publica eventos de workflow" "MQTT/AMQP"
        lowCodeService -> eventGrid "Publica eventos de integración" "MQTT/AMQP"
        billingService -> eventGrid "Publica eventos de suscripción" "MQTT/AMQP"
        
        # Event Grid -> Microservicios (consumidores)
        eventGrid -> notificationService "Entrega eventos para notificar" "HTTP Push"
        eventGrid -> analyticsService "Entrega eventos para agregación" "HTTP Push"
        
        # Comunicación síncrona entre microservicios (vía REST/gRPC)
        workflowService -> notificationService "Envía notificaciones al completar workflow" "REST"
        noCodeService -> contentService "Publica apps generadas" "REST"
        billingService -> profileService "Actualiza rol por suscripción" "REST"
        lowCodeService -> apiIntegrationService "Usa conectores predefinidos" "REST"
        aiService -> analyticsService "Consulta datos para respuestas" "gRPC/REST"
    }

    # ========== 7. VISTAS ==========
    views {
        # VISTA 1: Diagrama de Contexto (Pregunta 1)
        systemContext eduflow "Pregunta1_ContextDiagram" {
            title "Pregunta 1: Diagrama de Contexto - EduFlow Digital Corp."
            description "Muestra la interacción de usuarios y sistemas externos con la plataforma EduFlow Integrated Digital Platform."
            include *
            autoLayout lr
        }
        
        # VISTA 2: Diagrama de Contenedores (Pregunta 2)
        container eduflow "Pregunta2_ContainersDiagram" {
            title "Pregunta 2: Diagrama de Contenedores - Arquitectura de Microservicios"
            description "Muestra todos los contenedores: frontends, API Gateway, 12 microservicios (cada uno con su propia base de datos), Event Grid, y sistemas externos."
            
            # Frontends
            include webApp
            include mobileApp
            include powerAppsPortal
            
            # API Gateway
            include apiGateway
            
            # Microservicios
            include iamService
            include billingService
            include workflowService
            include noCodeService
            include lowCodeService
            include analyticsService
            include aiService
            include notificationService
            include contentService
            include profileService
            include apiIntegrationService
            include sharedService
            
            # Bases de datos (cada microservicio con la suya)
            include iamDatabase
            include billingDatabase
            include workflowDatabase
            include noCodeDatabase
            include lowCodeDatabase
            include analyticsDatabase
            include aiDatabase
            include notificationDatabase
            include contentDatabase
            include profileDatabase
            include apiIntegrationDatabase
            
            # Almacenamiento de archivos
            include noCodeStorage
            include contentStorage
            
            # Infraestructura compartida
            include eventGrid
            
            # Sistemas externos
            include sistemaPagos
            include sistemaERPCRM
            
            # Personas
            include clienteInstitucional
            include profesionalIndependiente
            include citizenDeveloper
            include administradorTI
            
            autoLayout lr
        }
        
        # ========== 8. ESTILOS ==========
        styles {
            element "Person" {
                shape person
                background #374151
                color #ffffff
            }
            element "Software System" {
                background #2563eb
                color #ffffff
            }
            element "External" {
                background #9ca3af
                color #ffffff
            }
            element "Pagos" {
                background #635bff
            }
            element "ERP" {
                background #ea580c
            }
            element "Container" {
                background #1d4ed8
                color #ffffff
            }
            element "Microservice" {
                background #0891b2
            }
            element "Database" {
                shape cylinder
                background #4b5563
                color #ffffff
            }
            element "Storage" {
                shape cylinder
                background #ea580c
                color #ffffff
            }
            element "MessageBroker" {
                background #0891b2
                color #ffffff
            }
            element "Angular" {
                background #dc2626
            }
            element "WebApp" {
                background #dc2626
            }
            element "MobileApp" {
                shape MobileDevicePortrait
                background #0284c7
            }
            element "PowerPlatform" {
                background #0f766e
            }
            element "Gateway" {
                background #7c3aed
            }
            element "Shared Kernel" {
                background #6b21a5
            }
        }
    }
}
